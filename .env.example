# ─────────────────────────────────────────────
# Supabase
# Get these from: https://supabase.com/dashboard → your project → Settings → API
# For local dev, run `supabase start` and copy from the terminal output
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─────────────────────────────────────────────
# OpenAI
# Get from: https://platform.openai.com/api-keys
# ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─────────────────────────────────────────────
# Resend (email delivery)
# Get from: https://resend.com/api-keys
# ─────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=stories@nestquill.com
RESEND_FROM_NAME=Nest & Quill

# ─────────────────────────────────────────────
# Stripe (payments — keep ENABLED=false until ready to charge real money)
# Get from: https://dashboard.stripe.com/apikeys
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_PAYMENTS_ENABLED=false

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase Edge Function base URL
# Local:      http://localhost:54321/functions/v1
# Production: https://<your-project-ref>.supabase.co/functions/v1
EDGE_FUNCTION_BASE_URL=http://localhost:54321/functions/v1
